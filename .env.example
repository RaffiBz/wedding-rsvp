# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# n8n webhook base. NOTE: paths are /rsvp-resolve, /rsvp-submit,
# /rsvp-admin-guests, /rsvp-admin-sent (appended to this base).
VITE_API_BASE=https://n8n.arachne-t.com/webhook

# Cloudflare Turnstile site key.
# For local dev use Cloudflare's always-pass test key so the widget never blocks:
#   1x00000000000000000000AA
# Swap in the real production key for the GitHub Pages build.
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Public URL of the deployed site (used to build WhatsApp RSVP links in /admin).
VITE_SITE_URL=https://RaffiBz.github.io/wedding-rsvp

# NOTE: there is intentionally no VITE_ADMIN_SECRET. The admin passcode is typed
# at runtime in /admin and kept in memory only — never committed or persisted.
